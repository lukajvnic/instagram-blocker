{
  "manifest_version": 3,
  "name": "Intentional Instagram",
  "version": "1.0.0",
  "description": "Turns Instagram into a messaging app and profile directory, not a feed.",
  "permissions": [
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "https://www.instagram.com/*"
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "instagram_redirects",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "content_scripts": [
    {
      "matches": ["https://www.instagram.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_start"
    }
  ]
}
